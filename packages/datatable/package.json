{
  "name": "@talentum-ventures/convex-datatable",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "react",
    "datatable",
    "data-grid",
    "tanstack-table",
    "convex",
    "typescript"
  ],
  "homepage": "https://github.com/talentum-ventures/convex-datatable/tree/main/packages/datatable",
  "bugs": {
    "url": "https://github.com/talentum-ventures/convex-datatable/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talentum-ventures/convex-datatable.git",
    "directory": "packages/datatable"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./convex": {
      "types": "./dist/convex/index.d.ts",
      "import": "./dist/convex/index.js"
    },
    "./convex-server": {
      "types": "./dist/convex/server.d.ts",
      "import": "./dist/convex/server.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:css": "tailwindcss -c tailwind.config.ts -i ./src/styles.css -o ./dist/styles.css --minify",
    "build": "bun run clean && bun run build:ts && bun run build:css",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "convex": "^1.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "peerDependenciesMeta": {
    "convex": {
      "optional": true
    }
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.11.2",
    "@tanstack/store": "^0.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "convex": "^1.32.0"
  }
}
